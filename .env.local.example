# ─────────────────────────────────────────────────────────────
# Kivana — Environment Variables
# Rename this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.kivana.co

# ── Stripe (Card Payments) ────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Safaricom Daraja (M-Pesa) ─────────────────────────────────
# Get from: https://developer.safaricom.co.ke
# Use sandbox values for testing: https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://www.kivana.co/api/mpesa/callback

# ── Formspree (Contact Form) ──────────────────────────────────
# Get from: https://formspree.io (free plan available)
NEXT_PUBLIC_FORMSPREE_ID=your_form_id

# ── Newsletter (choose one) ───────────────────────────────────
# Mailchimp: https://mailchimp.com/developer
MAILCHIMP_API_KEY=your_api_key
MAILCHIMP_AUDIENCE_ID=your_audience_id
MAILCHIMP_SERVER_PREFIX=us1

# ── Email (Order Confirmations) ───────────────────────────────
# Resend: https://resend.com (free 3000/month)
RESEND_API_KEY=re_...
EMAIL_FROM=orders@kivana.co

# ── Database (if you add one) ─────────────────────────────────
# Supabase: https://supabase.com
DATABASE_URL=postgresql://...
SUPABASE_ANON_KEY=your_anon_key

# ── Analytics ────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
